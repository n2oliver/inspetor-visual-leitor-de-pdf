{
  "manifest_version": 3,
  "name": "Inspetor Visual - Leitor de PDF",
  "version": "0.5.5",
  "default_locale": "en",
  "description": "Ouça audiobooks a partir de arquivos PDF no navegador.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "inspetorvisual@n2oliver.com"
    }
  },
  "action": {
    "default_popup": "insp.html",
    "default_icon": "insp-pdf.png"
  },
  "icons": {
    "16": "images/insp-pdf-16.png",
    "32": "images/insp-pdf-32.png",
    "48": "images/insp-pdf-48.png",
    "128": "images/insp-pdf-128.png"
  },
  "content_scripts": [
    {
      "js": ["dist/content.js"],
      "matches": [
        "<all_urls>"
      ],
     "run_at": "document_idle"
    }
  ]
}